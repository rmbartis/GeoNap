// MARK: - PrivacyView Body Text
"privacy.intro" = "NapStop được thiết kế với một nguyên tắc đơn giản: dữ liệu vị trí và báo thức của bạn thuộc về bạn. Tài liệu này giải thích chính xác thông tin nào ứng dụng sử dụng, chúng được lưu ở đâu và những gì nó không bao giờ làm.";

"privacy.body.locationData" = "NapStop sử dụng vị trí thiết bị của bạn độc quyền để theo dõi các vùng địa lý. Dữ liệu vị trí được xử lý hoàn toàn trên thiết bị của bạn — không bao giờ được truyền đến bất kỳ máy chủ nào, lưu trữ trong cơ sở dữ liệu, hoặc chia sẻ với bên thứ ba.\n\nKhi bạn tạo báo thức, vĩ độ, kinh độ và bán kính được lưu cục bộ. Dữ liệu này không rời thiết bị của bạn trừ khi bạn dùng nút Chia sẻ một cách rõ ràng, tạo ra liên kết Apple Maps tiêu chuẩn.\n\nỨng dụng yêu cầu quyền vị trí \"Luôn luôn\" để iOS có thể đánh thức ứng dụng trong nền khi bạn vào hoặc ra khỏi vùng được theo dõi. Bạn có thể thu hồi quyền này bất kỳ lúc nào trong Cài đặt iOS → Quyền riêng tư & Bảo mật → Dịch vụ vị trí → NapStop.";

"privacy.body.onDeviceStorage" = "Tất cả dữ liệu báo thức — bao gồm tên, tọa độ, bán kính, khung thời gian, ngày hoạt động và lịch sử kích hoạt — được lưu trữ cục bộ bằng SwiftData trong vùng chứa riêng của ứng dụng. Dữ liệu này được đưa vào các bản sao lưu iOS tiêu chuẩn (iCloud Backup hoặc iTunes/Finder) nếu sao lưu được bật.\n\nKhông cần tài khoản, đăng nhập hoặc kết nối mạng để sử dụng NapStop.";

"privacy.body.iCloudSync" = "NapStop được thiết kế để hỗ trợ đồng bộ iCloud qua CloudKit để báo thức của bạn có thể xuất hiện trên tất cả các thiết bị Apple đăng nhập cùng Apple ID. Khi đồng bộ iCloud đang hoạt động, hồ sơ báo thức được lưu trữ trong vùng chứa iCloud cá nhân của bạn và tuân theo chính sách quyền riêng tư của Apple. Apple không sử dụng dữ liệu CloudKit để quảng cáo.\n\nNếu đồng bộ iCloud không khả dụng hoặc bị tắt, ứng dụng tự động chuyển về lưu trữ chỉ cục bộ — không có dữ liệu bị mất. Bạn có thể tắt đồng bộ iCloud bất kỳ lúc nào trong Cài đặt → [Tên của bạn] → iCloud → NapStop.";

"privacy.body.transitFeeds" = "Tính năng Báo thức phương tiện tải xuống dữ liệu GTFS trực tiếp từ các máy chủ của cơ quan giao thông công cộng. Các nguồn này chứa tên điểm dừng, tọa độ và thông tin tuyến đường — không có dữ liệu cá nhân nào được bao gồm.\n\nDữ liệu GTFS đã tải xuống được lưu vào bộ nhớ đệm trong thư mục bộ nhớ đệm của ứng dụng trên thiết bị của bạn. Các tệp được lưu vào bộ nhớ đệm có thể bị iOS xóa khi bộ nhớ thấp; ứng dụng sẽ tải xuống lại theo yêu cầu.\n\nKhông có URL GTFS tùy chỉnh nào bạn nhập được lưu trữ ngoài phiên hiện tại, và không có thông tin nào về các cơ quan bạn đã duyệt được truyền đi bất kỳ đâu.";

"privacy.body.notifications" = "NapStop gửi thông báo cục bộ hoàn toàn trên thiết bị bằng UNUserNotificationCenter của iOS. Thông báo được tạo bởi chính ứng dụng khi sự kiện vùng địa lý xảy ra — chúng không được gửi qua bất kỳ máy chủ thông báo đẩy hoặc dịch vụ từ xa nào. Không có nội dung thông báo nào được truyền ra ngoài thiết bị của bạn.\n\nBạn có thể quản lý quyền thông báo trong Cài đặt iOS → Thông báo → NapStop.";

"privacy.body.analytics" = "NapStop không bao gồm bất kỳ SDK phân tích của bên thứ ba, mạng quảng cáo hoặc dịch vụ báo cáo sự cố nào. Ứng dụng không theo dõi cách bạn sử dụng nó và không thu thập thông tin chẩn đoán ngoài những gì iOS cung cấp tự nhiên trong Cài đặt → Quyền riêng tư & Bảo mật → Phân tích & Cải tiến.";

"privacy.body.dataDeletion" = "Bạn có thể xóa từng báo thức bằng cách vuốt sang trái trên bất kỳ hàng báo thức nào, hoặc xóa tất cả dữ liệu bằng cách xóa ứng dụng khỏi thiết bị. Gỡ cài đặt NapStop xóa tất cả hồ sơ báo thức được lưu trữ cục bộ. Nếu đồng bộ iCloud được bật, bạn cũng có thể xóa dữ liệu CloudKit của ứng dụng trong Cài đặt → [Tên của bạn] → iCloud → Quản lý bộ nhớ tài khoản → NapStop.";

"privacy.body.contact" = "Nếu bạn có câu hỏi về quyền riêng tư hoặc xử lý dữ liệu, bạn có thể liên hệ với nhà phát triển qua liên kết hỗ trợ trong App Store trên trang sản phẩm NapStop.";

