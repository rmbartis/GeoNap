// MARK: - HelpView Body Text
"help.body.minimumRequirements" = "GeoNap được thiết kế cho các thiết bị và hệ điều hành Apple sau:

• iPhone — iOS 26.0 trở lên
• iPad — iPadOS 26.0 trở lên
• Apple Watch — watchOS 26.0 trở lên (tính năng đồng hành)

Cần kết nối internet để tải dữ liệu lịch trình giao thông công cộng. Tất cả các chức năng báo thức khác hoạt động hoàn toàn ngoại tuyến.

Dịch vụ Vị trí phải được đặt thành Luôn luôn để cho phép báo thức kích hoạt trong nền.";
"help.body.whatIsNapAlarm" = "GeoNap đánh thức bạn dựa trên vị trí, không phải giờ giấc. Đặt báo thức tại bất kỳ địa điểm nào và ứng dụng thông báo ngay khi bạn đến — hoặc rời đi — để bạn thư giãn trên mọi hành trình.\n\n• Ngủ không lo lắng — ngủ yên tâm vì GeoNap sẽ đánh thức bạn đúng điểm dừng, mọi lúc.\n• Không bao giờ lỡ điểm dừng — không còn phụ thuộc vào thông báo bằng ngôn ngữ xa lạ hay loa hỏng.\n• Tự động thông báo cho người khác — cho gia đình, bạn bè hoặc đồng nghiệp biết ngay khi bạn đến hoặc đi.\n• Hỗ trợ Siri tùy chỉnh — tạo báo thức rảnh tay bằng giọng nói qua Phím tắt Siri.\n• Tóm tắt nhanh — mỗi báo thức hiển thị các cài đặt chính ngay trên màn hình chính.\n• CarPlay — báo thức hiện trên màn hình xe; dừng hoặc báo lại từ điện thoại.\n• Hỗ trợ 13 ngôn ngữ khác nhau.\n• Thông tin nhà ga được tải sẵn, cùng hỗ trợ trên toàn thế giới để tải dữ liệu giao thông từ đơn vị bạn chọn bằng bất kỳ nguồn cấp GTFS công khai qua URL nào.\n• Ghi nhật ký tích hợp — bật nhật ký gỡ lỗi trong Cài đặt để ghi lại hoạt động chi tiết cho báo cáo hỗ trợ.\n• Thông báo cho bạn bè, gia đình hoặc đồng nghiệp về thời điểm khởi hành và đến nơi của bạn.";

"help.body.featureSummary" = "Ứng dụng\n\n• Tổng quan bản đồ — xem tất cả báo thức đã lưu trên một bản đồ duy nhất.\n• Danh sách báo thức — liệt kê đầy đủ mọi báo thức với trạng thái, huy hiệu và chi tiết kích hoạt trong nháy mắt.\n• Tạo theo vị trí hoặc phương tiện — ghim địa chỉ trên bản đồ hoặc duyệt lịch trình trực tiếp để chọn điểm dừng chính xác.\n• Nguồn dữ liệu phương tiện tùy chỉnh — nhập thủ công URL GTFS công khai để tải lịch trình từ bất kỳ cơ quan nào trên thế giới.\n• Ghi nhật ký tích hợp — bật nhật ký gỡ lỗi trong Cài đặt để ghi lại hoạt động chi tiết cho báo cáo hỗ trợ.\n\nBáo thức cá nhân\n\n• Tên và ghi chú — đặt tên cho từng báo thức và ghi chú tùy chọn xuất hiện trong thông báo.\n• Nhập vị trí linh hoạt — đặt ghim bằng cách chạm vào bản đồ, tìm kiếm địa chỉ hoặc nhập tọa độ (DD, DMS hoặc DDM).\n• Kích hoạt khi đến hoặc đi — chọn báo thức kích hoạt khi bạn vào hay rời khỏi khu vực.\n• Bán kính có thể điều chỉnh — đặt kích thước vùng địa lý bằng thanh trượt; ranh giới hiển thị trực tiếp trên bản đồ.\n• Âm thanh tùy chỉnh — chọn từ âm thanh du lịch, mặc định hệ thống hoặc chỉ rung.\n• Lên lịch — giới hạn báo thức theo ngày trong tuần và khung giờ cụ thể, với tùy chọn lặp lại sau mỗi chuyến đi.\n• Tự động thông báo — tự động gửi tin nhắn đến danh bạ đã lưu khi báo thức kích hoạt.\n\nCá nhân hóa\n\n• Đơn vị khoảng cách và thời gian — chuyển đổi giữa hệ mét và Anh, và giữa đồng hồ 12 hoặc 24 giờ.\n• Định dạng tọa độ — nhập và xem tọa độ GPS theo DD, DMS hoặc DDM.\n• Mười ba ngôn ngữ — GeoNap được bản địa hóa hoàn toàn sang tiếng Anh, Tây Ban Nha, Pháp, Đức, Ý, Bồ Đào Nha, Ả Rập, Hindi, Nhật, Trung Quốc giản thể, Nga, Thái và Việt.\n• Danh bạ mặc định Tự động thông báo — duy trì danh sách liên hệ toàn cục tự động điền vào mọi báo thức mới có Tự động thông báo được bật.";
"help.body.useCases" = "• Hành khách tàu hỏa hoặc tàu điện ngầm — Đặt báo thức tại ga của bạn. Ngủ một giấc và được đánh thức ngay trước khi đến, mỗi buổi sáng, tự động.\n\n• Hành khách xe buýt — Đặt báo thức khởi hành tại trạm gần nhà. Báo thức sẽ kêu khi bạn rời khỏi khu vực, nhắc nhở bạn ra đi.\n\n• Hành khách đường trường — Đặt báo thức tại một thành phố trung gian. Bạn sẽ được thông báo khi xe đến gần mà không cần nhìn vào bản đồ suốt chuyến đi.\n\n• Du khách ở thành phố lạ — Đặt báo thức tại khách sạn, sân bay hoặc địa điểm họp để luôn biết khi nào bạn đang đến gần.";

"help.body.creatingAlarm" = "Nhấn + ở góc trên bên phải. Một menu xuất hiện với hai lựa chọn:

• Báo thức vị trí — ghim bất kỳ địa chỉ hoặc vị trí nào trên bản đồ.
• Báo thức phương tiện — chọn cơ quan, tuyến đường và điểm dừng từ lịch trình trực tiếp.

Với Báo thức vị trí:

1. Đặt tên cho báo thức và ghi chú tùy chọn sẽ xuất hiện trong thông báo.
2. Dùng thanh tìm kiếm để tìm bất kỳ địa chỉ, ga hay địa điểm nào. Nhấn vào gợi ý để thả ghim, hoặc nhấn trực tiếp lên bản đồ.
3. Để đặt vị trí bằng tọa độ, nhấn Nhập tọa độ. Nhập hoặc dán tọa độ GPS theo định dạng DD, DMS hoặc DDM, rồi nhấn Áp dụng để thả ghim.
4. Chọn Khi đến nơi hoặc Khi khởi hành làm điều kiện kích hoạt.
5. Dùng thanh trượt Bán kính để đặt khoảng cách cần thiết trước khi báo thức kêu.
6. Trong Âm thanh / Rung, chọn nhạc chuông hoặc chọn Chỉ rung.
7. Tùy chọn bật Tự động thông báo để tự động nhắn tin đến các liên hệ đã lưu khi báo thức kêu.

Nút Lưu bị tắt cho đến khi nhập tên và ghim vị trí. iOS cho phép tối đa 20 báo thức đang hoạt động cùng lúc.";

"help.body.radius" = "Bán kính xác định vùng địa lý — ranh giới hình tròn quanh ghim của bạn. Khi bạn vượt qua ranh giới đó (vào hoặc ra), báo thức kêu.\n\nBán kính 200 m phù hợp cho một ga hoặc tòa nhà. Dùng 500–1000 m cho các mốc rộng hơn như trung tâm thành phố hoặc khu vực sân bay, giúp bạn có thêm thời gian chuẩn bị trước khi đến.\n\nBạn có thể chuyển đổi giữa mét/kilômét và feet/dặm trong Cài đặt.";

"help.body.repeat" = "Báo thức một lần kêu một lần và ở trạng thái đã kích hoạt cho đến khi bạn bật lại thủ công. Hữu ích cho một chuyến đi đơn lẻ hoặc nhắc nhở một lần.\n\nBáo thức lặp lại tự động đặt lại sau khi bạn rời vùng, vì vậy sẽ kêu lại vào lần tiếp theo bạn đi qua cùng vị trí đó. Hoàn hảo cho người đi lại hàng ngày.";

"help.body.timeWindow" = "Khung thời gian giới hạn khi nào báo thức được phép kêu. Ví dụ, khung 07:00–09:00 nghĩa là báo thức chỉ kích hoạt trong giờ đi làm buổi sáng của bạn.\n\nNhãn tóm tắt bên dưới bộ chọn hiển thị chính xác khung thời gian dài bao lâu, ví dụ \"Hoạt động 2 giờ · 7:00 – 9:00\".\n\nKhung thời gian qua đêm được hỗ trợ (ví dụ 22:00–06:00). Khi giờ Từ muộn hơn Đến, báo thức hoạt động qua nửa đêm đến sáng hôm sau. Tóm tắt chuyển màu cam và hiển thị \"ngày hôm sau\" nhắc nhở.";

"help.body.transitAlarms" = "Báo thức phương tiện kết nối với lịch trình giao thông công cộng để bạn có thể đặt báo thức tại một điểm dừng cụ thể mà không cần nhập tọa độ GPS.\n\nNhấn + → Báo thức phương tiện để mở trình hướng dẫn:\n\n1. Cơ quan — Chọn từ danh sách tích hợp toàn cầu (Amtrak, BART, MBTA, CTA, GO Transit và nhiều hơn), hoặc nhập bất kỳ URL nguồn GTFS công khai nào.\n2. Tuyến đường — Duyệt hoặc tìm kiếm tuyến. Mỗi tuyến hiển thị loại (Đường sắt, Tàu điện ngầm, Xe buýt, Phà, v.v.).\n3. Điểm dừng — Tất cả điểm dừng được liệt kê theo khoảng cách từ vị trí hiện tại của bạn.\n4. Xác nhận — Xem lại cơ quan, tuyến và điểm dừng, sau đó đặt tên, bán kính, hướng kích hoạt và âm thanh.\n\nỨng dụng tải nguồn GTFS khi sử dụng lần đầu và lưu vào bộ nhớ đệm cục bộ.";

"help.body.soundVibrate" = "Mỗi báo thức có cài đặt âm thanh riêng được chọn trong Âm thanh / Rung khi tạo hoặc chỉnh sửa.\n\nTùy chọn hệ thống:\n• Chỉ rung — không có âm thanh; lý tưởng cho môi trường yên tĩnh.\n• Mặc định — âm thanh thông báo iOS tiêu chuẩn.\n• Khẩn cấp — phát ở âm lượng tối đa, bỏ qua chế độ im lặng và Không làm phiền.\n\nÂm thanh du lịch tích hợp:\n• Còi tàu thuyền · Chuông xe cáp · Tàu hơi nước · Chuông thuyền buồm · Máy bay hạ cánh · Chuông sân bay\n\nMỗi cài đặt được lưu cùng báo thức và phát mỗi khi nó kêu.";

"help.body.siri" = "GeoNap hỗ trợ Siri và ứng dụng Phím tắt — không cần thiết lập.\n\n• “Tạo một GeoNap” — Siri hỏi tên, vị trí và hướng kích hoạt, rồi lưu báo thức.\n• “Bật GeoNap của tôi” — Siri hiển thị các báo thức đã lưu; chọn một để bật lại.\n• “Tắt GeoNap của tôi” — Giống như trên, nhưng vô hiệu hóa báo thức.\n• “Thông báo cho liên hệ của tôi qua GeoNap” — Trả về nội dung tin nhắn soạn sẵn của báo thức kêu gần nhất. Được thiết kế để dùng trong Tự động hóa cá nhân (xem bên dưới).\n\nGửi SMS không cần phê duyệt bằng Tự động hóa cá nhân:\nKết hợp phím tắt “Thông báo cho liên hệ qua GeoNap” với Phím tắt của iOS để gửi tin nhắn Tự động thông báo mà không cần màn hình soạn và không cần chạm Gửi. iOS không có trình kích hoạt theo thông báo, nên tự động hóa dùng “Khi GeoNap được mở” — SMS được gửi vào lần tiếp theo bạn mở GeoNap sau khi báo thức kêu.\n\nXem Cài đặt → Auto-SMS (không cần phê duyệt) để biết các bước thiết lập đầy đủ.\n\nBạn cũng có thể tìm và tùy chỉnh tất cả phím tắt trong ứng dụng Phím tắt của iOS, trong mục GeoNap.";

"help.body.settings" = "Mở Cài đặt từ biểu tượng bánh răng ở góc trên bên trái của danh sách báo thức. Nhấn ⓘ bên cạnh bất kỳ cài đặt nào để xem giải thích chi tiết.

• Khoảng cách — chuyển đổi giữa hệ mét (mét / kilômét) và hệ đo lường (feet / dặm).
• Tọa độ — chọn định dạng tọa độ GPS: DD (Độ thập phân), DMS (Độ Phút Giây) hoặc DDM (Độ Phút thập phân).
• Đồng hồ — chuyển đổi giữa định dạng 12 giờ và 24 giờ.
• Ngôn ngữ — thay đổi ngôn ngữ hiển thị độc lập với ngôn ngữ hệ thống của iPhone.
• Mặc định tự động thông báo — thêm liên hệ điện thoại tại đây. Các thay đổi trong danh sách này sẽ tự động được phản ánh vào tất cả báo thức hiện có đã bật Tự động thông báo. Bạn vẫn có thể điều chỉnh danh bạ cho từng báo thức.
• Trợ giúp & Hướng dẫn sử dụng — hướng dẫn này.
• Quyền riêng tư & Chia sẻ vị trí — toàn bộ thông tin về cách xử lý dữ liệu vị trí.
• Bật nhật ký gỡ lỗi — xem \"Báo cáo sự cố\" bên dưới.
• Bản dựng — hiển thị phiên bản hiện tại theo định dạng MajorVersion.GitBuildNumber-Date (ví dụ: 1.247-20260529). Bao gồm khi báo cáo lỗi.";

"help.body.reportingProblem" = "Nếu GeoNap không hoạt động như mong đợi, bạn có thể bật ghi nhật ký gỡ lỗi để thu thập hồ sơ chi tiết.\n\nĐể bật ghi nhật ký:\n1. Mở Cài đặt → phần Hỗ trợ.\n2. Bật Nhật ký gỡ lỗi.\n3. Hộp thoại giải thích những gì được ghi lại. Nhấn Bật ghi nhật ký để tiếp tục.\n4. Tái hiện sự cố.\n5. Mở ứng dụng Files → Trên iPhone của tôi → GeoNap → GeoNapDebug.log, sau đó chia sẻ với bộ phận hỗ trợ.\n\nNhững gì được ghi lại: kiểu thiết bị, phiên bản iOS, trạng thái quyền vị trí, sự kiện vùng, sự kiện báo thức, tải xuống nguồn phương tiện và lỗi. Không có gì được gửi tự động.";

"help.body.alarmIcons" = "Mỗi hàng báo thức hiển thị một chấm trạng thái, huy hiệu tùy chọn và biểu tượng trạng thái bên phải.\n\nChấm trạng thái (ngoài cùng bên trái):\n• Xanh lá — đang hoạt động, theo dõi vị trí của bạn.\n• Đỏ — báo thức đã kích hoạt.\n• Cam — đang tạm hoãn 10 phút.\n• Xám — đã tắt.\n\nHuy hiệu ở giữa (chỉ hiển thị khi phù hợp):\n• Biểu tượng phương tiện màu mòng két — báo thức phương tiện. Hình dạng phản ánh loại tuyến: tàu, tàu điện ngầm, xe buýt, phà, v.v.\n• Mũi tên lặp lại màu xanh dương — báo thức tự đặt lại sau mỗi chuyến đi.\n• Loa khuếch đại màu xanh lá — Tự động thông báo bật; các liên hệ sẽ nhận tin nhắn khi báo thức kích hoạt.\n• Chuông xám có gạch chéo — âm thanh được đặt thành Chỉ rung, không phát âm thanh.\n• Khoảng thời gian màu tím — báo thức chỉ hoạt động trong khung giờ cụ thể.\n• Chữ ngày màu cam — báo thức chỉ hoạt động vào các ngày được chọn trong tuần.\n\nBiểu tượng bên phải:\n• Chuông đỏ có huy hiệu — báo thức đã kích hoạt và đang chờ xác nhận hoặc tạm hoãn.\n• Mặt trăng cam có chữ Z — báo thức đang trong trạng thái tạm hoãn.";
"help.body.managingAlarms" = "Vuốt sang phải trên bất kỳ báo thức nào trong danh sách để nhanh chóng bật hoặc tắt mà không cần mở chế độ xem chi tiết.\n\nVuốt sang trái để xóa báo thức. Báo thức bị xóa ngay lập tức và việc giám sát vùng địa lý của chúng dừng lại.\n\nĐể chỉnh sửa báo thức, nhấn vào để mở chế độ xem chi tiết, sau đó nhấn Chỉnh sửa báo thức.\n\nĐể chia sẻ vị trí báo thức, mở chế độ xem chi tiết và nhấn Chia sẻ vị trí báo thức. Thao tác này chia sẻ liên kết Apple Maps cố định đến tọa độ đã ghim của báo thức — hữu ích để báo cho ai đó biết điểm đến của bạn trước khi đi. Bạn có thể chia sẻ bất cứ lúc nào, không chỉ khi báo thức kêu.";

"help.body.alwaysOnLocation" = "GeoNap cần quyền truy cập vị trí Luôn bật để theo dõi các vùng trong nền — ngay cả khi màn hình của bạn bị khóa hoặc ứng dụng đã đóng.\n\nNếu bạn đã chọn Không phải bây giờ trong quá trình thiết lập, bạn có thể cấp quyền sau trong Cài đặt iOS → Quyền riêng tư & Bảo mật → Dịch vụ vị trí → GeoNap. Đặt thành Luôn luôn.\n\nKhông có quyền truy cập Luôn bật, báo thức sẽ chỉ kêu khi ứng dụng đang mở.";

"help.body.notifications" = "Khi báo thức kêu, iOS hiển thị báo thức toàn màn hình với Dừng và Báo lại — cả trên Màn hình khóa — và xuyên qua chế độ im lặng và Tập trung.\n\n• Dừng kết thúc báo thức. Báo thức lặp lại tự đặt lại khi bạn rời khỏi khu vực.\n• Báo lại hoãn báo thức 10 phút; chạm Báo lại mỗi lần để tiếp tục hoãn.\n\nNếu Tự động báo đang bật, một bản nháp Tin nhắn gửi đến danh bạ của bạn sẽ mở vào lần tiếp theo bạn mở GeoNap, điền sẵn thông tin — ví dụ: “[Đến] Tôi đã đến [điểm dừng] lúc [giờ].” Chạm Gửi, hoặc thiết lập gửi rảnh tay (xem Tự động báo).\n\nCarPlay — báo thức hiện trên màn hình, nhưng âm thanh không phát qua xe. Dùng điện thoại (Màn hình khóa hoặc ứng dụng) để dừng hoặc báo lại.";
