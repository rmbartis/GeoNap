// MARK: - HelpView Body Text
"help.body.minimumRequirements" = "GeoNap निम्नलिखित Apple डिवाइस और ऑपरेटिंग सिस्टम के लिए डिज़ाइन किया गया है:

• iPhone — iOS 17.0 या बाद का
• iPad — iPadOS 17.0 या बाद का
• Apple Watch — watchOS 10.0 या बाद का (साथी सुविधाएँ)

ट्रांज़िट अलार्म फ़ीड डाउनलोड करने के लिए इंटरनेट कनेक्शन आवश्यक है। अन्य सभी अलार्म फ़ंक्शन पूरी तरह ऑफ़लाइन काम करते हैं।

पृष्ठभूमि में अलार्म चालू होने के लिए स्थान सेवाएँ हमेशा पर सेट होनी चाहिए।";
"help.body.whatIsNapAlarm" = "GeoNap आपको समय के बजाय आपकी स्थान के आधार पर जगाता है। किसी भी स्थान पर अलार्म सेट करें और ऐप आपके पहुँचते ही — या जाते ही — आपको सूचित कर देगा, ताकि आप किसी भी यात्रा में आराम कर सकें।\n\n• बेफ़िक्र होकर सोएं — आश्वस्त रहें कि GeoNap हर बार आपके स्टॉप पर आपको जगाएगा।\n• स्टॉप कभी न चूकें — किसी अपरिचित भाषा में घोषणाओं या टूटे स्पीकरों पर निर्भर रहने की ज़रूरत नहीं।\n• दूसरों को स्वतः सूचित करें — पहुँचने या जाने के पल में दोस्तों, परिवार या सहकर्मियों को बताएं।\n• कस्टमाइज़ करने योग्य Siri सपोर्ट — Siri Shortcuts से अपनी आवाज़ से हैंड्स-फ्री अलार्म बनाएं।\n• एक नज़र में सारांश — प्रत्येक अलार्म अपनी मुख्य सेटिंग्स सीधे होम स्क्रीन पर दिखाता है।";

"help.body.featureSummary" = "ऐप\n\n• मैप अवलोकन — एक मैप पर सभी सहेजे गए अलार्म देखें।\n• अलार्म सूची — स्थिति, बैज और ट्रिगर विवरण के साथ हर अलार्म की पूरी सूची एक नज़र में।\n• स्थान या ट्रांज़िट से बनाएं — मैप पर पिन लगाएं या सटीक स्टॉप चुनने के लिए लाइव शेड्यूल ब्राउज़ करें।\n• कस्टम ट्रांज़िट फ़ीड — किसी भी एजेंसी का शेड्यूल लोड करने के लिए मैन्युअल रूप से सार्वजनिक GTFS फ़ीड URL दर्ज करें।\n• बिल्ट-इन लॉगिंग — सहायता रिपोर्ट के लिए विस्तृत गतिविधि कैप्चर करने हेतु सेटिंग्स में डीबग लॉग सक्षम करें।\n\nव्यक्तिगत अलार्म\n\n• नाम और नोट्स — प्रत्येक अलार्म को एक नाम और वैकल्पिक नोट दें जो सूचना में दिखाई देता है।\n• लचीला स्थान प्रविष्टि — मैप टैप करके पिन लगाएं, पता खोजें, या निर्देशांक टाइप करें (DD, DMS या DDM)।\n• आगमन या प्रस्थान ट्रिगर — चुनें कि अलार्म क्षेत्र में प्रवेश करने या छोड़ने पर बजे।\n• समायोज्य त्रिज्या — स्लाइडर से जियोफ़ेंस का आकार सेट करें; सीमा मैप पर लाइव दिखती है।\n• कस्टम ध्वनियाँ — बंडल ट्रैवल साउंड, सिस्टम डिफ़ॉल्ट, क्रिटिकल अलर्ट या केवल वाइब्रेट में से चुनें।\n• शेड्यूलिंग — अलार्म को विशिष्ट दिनों और समय-सीमा तक सीमित करें, प्रत्येक यात्रा के बाद वैकल्पिक दोहराव के साथ।\n• स्वतः सूचना — अलार्म बजने पर सहेजे गए संपर्कों को स्वतः संदेश भेजें।\n\nव्यक्तिगतकरण\n\n• दूरी और समय इकाइयाँ — मेट्रिक और इंपीरियल, और 12 या 24 घंटे की घड़ी के बीच बदलें।\n• निर्देशांक प्रारूप — DD, DMS या DDM के रूप में GPS निर्देशांक दर्ज और देखें।\n• तेरह भाषाएँ — GeoNap अंग्रेज़ी, स्पेनिश, फ्रेंच, जर्मन, इतालवी, पुर्तगाली, अरबी, हिंदी, जापानी, सरलीकृत चीनी, रूसी, थाई और वियतनामी में पूरी तरह स्थानीयकृत है।\n• स्वतः सूचना डिफ़ॉल्ट — एक वैश्विक संपर्क सूची बनाए रखें जो स्वतः सूचना सक्षम हर नए अलार्म में स्वतः भर जाती है।";
"help.body.useCases" = "• ट्रेन या मेट्रो यात्री — अपने स्टेशन पर अलार्म सेट करें। सो जाएँ और पहुँचने से पहले जाग जाएँ, हर सुबह स्वतः।\n\n• बस यात्री — अपने घर के नज़दीकी स्टॉप पर प्रस्थान अलार्म सेट करें। जब आप क्षेत्र छोड़ें तो अलार्म बजे, जो आपको निकलने की याद दिलाए।\n\n• रोड ट्रिप यात्री — किसी वेपॉइंट शहर पर अलार्म सेट करें। पूरी यात्रा नक्शा देखे बिना, जब गाड़ी पास पहुँचे तब सूचना मिलेगी।\n\n• अनजान शहर में यात्री — होटल, हवाई अड्डे या मीटिंग स्थानों पर अलार्म सेट करें ताकि हमेशा पता रहे कि कब पास आ रहे हैं।";

"help.body.creatingAlarm" = "ऊपरी दाएँ कोने में + दबाएँ। दो विकल्पों के साथ मेनू आता है:

• लोकेशन अलार्म — कोई भी पता या नक्शे की जगह पिन करें।
• ट्रांज़िट अलार्म — लाइव शेड्यूल से एजेंसी, रूट और स्टॉप चुनें।

लोकेशन अलार्म के लिए:

1. अलार्म को नाम दें और वैकल्पिक नोट जोड़ें जो सूचना में दिखेगा।
2. सर्च बार से कोई पता, स्टेशन या जगह खोजें। सुझाव पर टैप करके पिन लगाएँ, या नक्शे पर सीधे टैप करें।
3. निर्देशांक द्वारा स्थान सेट करने के लिए, निर्देशांक दर्ज करें पर टैप करें। DD, DMS या DDM फॉर्मेट में GPS निर्देशांक टाइप या पेस्ट करें, फिर पिन लगाने के लिए लागू करें पर टैप करें।
4. ट्रिगर के रूप में पहुँचने पर या जाने पर चुनें।
5. रेडियस स्लाइडर से तय करें कि अलार्म बजने से पहले कितना पास होना ज़रूरी है।
6. साउंड / वाइब्रेट में कोई टोन चुनें या केवल वाइब्रेट चुनें।
7. अलार्म बजने पर सहेजे गए संपर्कों को स्वतः संदेश भेजने के लिए वैकल्पिक रूप से स्वतः सूचना सक्षम करें।

सेव बटन तब तक निष्क्रिय रहेगा जब तक नाम न डाला हो और लोकेशन पिन न की हो। iOS एक साथ अधिकतम 20 सक्रिय अलार्म की अनुमति देता है।";

"help.body.radius" = "रेडियस जियोफेंस को परिभाषित करता है — आपके पिन के चारों ओर गोलाकार सीमा। जब आप उस सीमा को पार करते हैं (प्रवेश या निकास), अलार्म बजता है।\n\n200 मी रेडियस एक स्टेशन या इमारत के लिए उचित है। व्यापक स्थलों जैसे शहर केंद्र या हवाई अड्डे के लिए 500–1000 मी उपयोग करें, ताकि पहुँचने से पहले तैयार होने का समय मिले।\n\nआप सेटिंग्स में मीटर/किलोमीटर और फीट/मील के बीच बदल सकते हैं।";

"help.body.repeat" = "सिंगल अलार्म एक बार बजता है और जब तक आप मैन्युअली दोबारा चालू न करें, ट्रिगर्ड स्थिति में रहता है। एक बार की यात्रा या एकमुश्त याद के लिए उपयोगी।\n\nबार-बार दोहराने वाले अलार्म क्षेत्र छोड़ने के बाद स्वतः रीसेट हो जाते हैं, इसलिए अगली बार उसी जगह से गुज़रने पर फिर बजते हैं। रोज़ाना यात्रा करने वालों के लिए बेहतर।";

"help.body.timeWindow" = "टाइम विंडो सीमित करती है कि अलार्म कब बज सकता है। उदाहरण के लिए, 07:00–09:00 की विंडो का मतलब है कि अलार्म केवल सुबह की यात्रा के दौरान ट्रिगर होगा।\n\nपिकर्स के नीचे सारांश लेबल दिखाता है कि विंडो कितनी लंबी है, जैसे \"2 घंटे सक्रिय · 7:00 AM – 9:00 AM\"।\n\nरात भर की विंडो समर्थित हैं (जैसे 22:00–06:00)। जब शुरुआती समय, खत्म होने के समय के बाद हो, अलार्म आधी रात के बाद अगली सुबह तक सक्रिय रहता है। सारांश नारंगी हो जाता है और \"अगला दिन\" याद दिलाने के लिए दिखता है।";

"help.body.transitAlarms" = "ट्रांज़िट अलार्म सार्वजनिक परिवहन शेड्यूल से जुड़ते हैं ताकि आप GPS निर्देशांक टाइप किए बिना किसी स्टेशन स्टॉप पर अलार्म सेट कर सकें।\n\n+ → ट्रांज़िट अलार्म दबाएँ:\n\n1. एजेंसी — बिल्ट-इन विश्वव्यापी सूची (Amtrak, BART, MBTA, CTA, GO Transit आदि) से चुनें, या कोई GTFS फ़ीड URL दर्ज करें।\n2. रूट — रूट ब्राउज़ करें या खोजें। प्रत्येक अपना प्रकार दिखाता है (रेल, मेट्रो, बस, फेरी आदि)।\n3. स्टॉप — सभी स्टॉप आपकी वर्तमान लोकेशन से दूरी के क्रम में सूचीबद्ध।\n4. पुष्टि — एजेंसी, रूट और स्टॉप की समीक्षा करें, फिर नाम, रेडियस, ट्रिगर दिशा और साउंड सेट करें।\n\nपहली बार उपयोग पर ऐप GTFS फ़ीड डाउनलोड करता है और स्थानीय रूप से कैश करता है।";

"help.body.soundVibrate" = "प्रत्येक अलार्म की अपनी साउंड सेटिंग होती है जो बनाते या संपादित करते समय साउंड / वाइब्रेट में चुनी जाती है।\n\nसिस्टम विकल्प:\n• केवल वाइब्रेट — कोई आवाज़ नहीं; शांत वातावरण के लिए आदर्श।\n• डिफ़ॉल्ट — मानक iOS सूचना ध्वनि।\n• क्रिटिकल — साइलेंट मोड और डू नॉट डिस्टर्ब को बायपास करते हुए पूरी आवाज़ में बजती है।\n\nबिल्ट-इन ट्रैवल साउंड:\n• जहाज़ का हॉर्न · केबल कार बेल · स्टीम ट्रेन · नौकायान घंटी · विमान लैंडिंग · हवाई अड्डा चाइम\n\nप्रत्येक सेटिंग अलार्म के साथ सहेजी जाती है और हर बार बजने पर चलती है।";

"help.body.siri" = "GeoNap Siri और Shortcuts ऐप को सपोर्ट करता है — कोई सेटअप नहीं चाहिए।\n\n• \"GeoNap बनाओ\" — Siri नाम, लोकेशन और ट्रिगर दिशा पूछती है, फिर अलार्म सहेजती है।\n• \"मेरा GeoNap चालू करो\" — Siri आपके सहेजे अलार्म दिखाती है; दोबारा चालू करने के लिए एक चुनें।\n• \"मेरा GeoNap बंद करो\" — ऊपर की तरह, लेकिन अलार्म निष्क्रिय करता है।\n\nआप इन्हें iOS Shortcuts ऐप के GeoNap सेक्शन में भी ढूँढ और अनुकूलित कर सकते हैं।
- 'GeoNap ke madhyam se mere contacts ko suchit karen' - Haal hi mein fire hue alarm ke liye purv-bhare sandesh ka mukhya bhag lautata hai. Vyaktigat automation mein upayog ke liye dizain kiya gaya.

Vyaktigat automation ka upayog karke SMS bina anumodan ke bhejen:
Poori tarah se svachalit roop se Auto-Notify sandesh bhejne ke liye 'GeoNap ke madhyam se contacts ko suchit karen' shortcut ko iOS Shortcuts app ke saath milaen - koi compose sheet nahin, koi 'Bhejein tap karen' nahin.

Purn setup ke liye Settings - Auto-SMS (Anumodan ki aavashyakta nahin) dekhen.\n• «GeoNap के माध्यम से मेरे संपर्कों को सूचित करें» — हाल ही में फ़ायर हुए अलार्म के लिए पूर्व-भरे संदेश का मुख्य भाग लौटाता है। व्यक्तिगत ऑटोमेशन में उपयोग के लिए डिज़ाइन किया गया।\n\nव्यक्तिगत ऑटोमेशन का उपयोग करके SMS बिना अनुमोदन के भेजें:\nपूरी तरह से स्वचालित रूप से ऑटो-नोटिफ़ाई संदेश भेजने के लिए «GeoNap के माध्यम से संपर्कों को सूचित करें» शॉर्टकट को iOS Shortcuts ऐप के साथ मिलाएं — कोई कम्पोज़ शीट नहीं, कोई ‘भेजें टैप करें’ नहीं।\n\nपूर्ण सेटअप के लिए सेटिंग्स → ऑटो-SMS (अनुमोदन की आवश्यकता नहीं) देखें।\n• «GeoNap के माध्यम से मेरे संपर्कों को सूचित करें» — हाल ही में फ़ायर हुए अलार्म के लिए पूर्व-भरे संदेश का मुख्य भाग लौटाता है। व्यक्तिगत ऑटोमेशन में उपयोग के लिए डिज़ाइन किया गया।\n\nव्यक्तिगत ऑटोबेशन का उपयोग करके SMS बिना अनुमोदन के भेजें:\nपूरी तरह से स्वचालित रूप से ऑटो-नोटिफ़ाइ संदेश भेजने के लिए «GeoNap के माध्यम से संपर्कों को सूचित करें» शॉर्टकट को iOS Shortcuts ऐप के साथ मिलाएं — कोई कम्पोज़ शीट नहीं, कोई 'भेजें टैप करें' नहीं।\n\nपूर्ण सेटअप के लिए सेटिंग्स → ऑटो-SMS (अनुमोदन की आवश्यकता नहीं) देखें।";

"help.body.settings" = "अलार्म सूची के ऊपरी बाएँ कोने में गियर आइकन से सेटिंग्स खोलें। किसी भी सेटिंग के पास ⓘ टैप करें विस्तृत विवरण के लिए।

• दूरी — मेट्रिक (मीटर / किलोमीटर) और इंपीरियल (फीट / मील) के बीच बदलें।
• निर्देशांक — GPS निर्देशांक प्रारूप चुनें: DD (दशमलव डिग्री), DMS (डिग्री मिनट सेकंड) या DDM (डिग्री दशमलव मिनट)।
• घड़ी — 12 घंटे और 24 घंटे समय के बीच बदलें।
• भाषा — iPhone की सिस्टम भाषा से स्वतंत्र रूप से प्रदर्शन भाषा बदलें।
• स्वतः सूचना डिफ़ॉल्ट — यहाँ फ़ोन संपर्क जोड़ें। इस सूची में बदलाव उन सभी मौजूदा अलार्मों में स्वतः लागू हो जाते हैं जिनमें स्वतः सूचना सक्षम है। आप प्रत्येक अलार्म के लिए संपर्क अलग से भी बदल सकते हैं।
• सहायता और उपयोगकर्ता गाइड — यह गाइड।
• गोपनीयता और लोकेशन शेयरिंग — लोकेशन डेटा संभालने का पूरा विवरण।
• डीबग लॉग सक्षम करें — नीचे \"समस्या रिपोर्ट करना\" देखें।
• बिल्ड — वर्तमान संस्करण MajorVersion.GitBuildNumber-Date (उदाहरण: 1.247-20260529) प्रारूप में दिखाता है। बग रिपोर्ट करते समय इसे शामिल करें।";

"help.body.reportingProblem" = "अगर GeoNap अपेक्षित रूप से काम नहीं कर रहा, तो विस्तृत रिकॉर्ड के लिए डीबग लॉगिंग सक्षम कर सकते हैं।\n\nलॉगिंग सक्षम करने के लिए:\n1. सेटिंग्स → सपोर्ट सेक्शन खोलें।\n2. डीबग लॉग सक्षम करें को चालू करें।\n3. एक डायलॉग बताता है क्या रिकॉर्ड होगा। जारी रखने के लिए लॉगिंग सक्षम करें दबाएँ।\n4. समस्या फिर से करें।\n5. Files ऐप → मेरे iPhone पर → GeoNap → GeoNapDebug.log खोलें, फिर सपोर्ट से शेयर करें।\n\nक्या रिकॉर्ड होता है: डिवाइस मॉडल, iOS वर्शन, लोकेशन अनुमति स्थिति, क्षेत्र इवेंट, अलार्म इवेंट, ट्रांज़िट फ़ीड डाउनलोड और त्रुटियाँ। कुछ भी स्वतः नहीं भेजा जाता।";

"help.body.alarmIcons" = "प्रत्येक अलार्म पंक्ति एक स्थिति बिंदु, वैकल्पिक बैज और दाईं ओर स्थिति आइकन दिखाती है।\n\nस्थिति बिंदु (बाईं ओर):\n• हरा — सक्रिय, आपकी लोकेशन मॉनिटर कर रहा है।\n• लाल — अलार्म बज चुका है।\n• नारंगी — 10 मिनट के लिए स्नूज़ है।\n• धूसर — निष्क्रिय।\n\nबीच के बैज (केवल तभी दिखाए जाते हैं जब प्रासंगिक हों):\n• टील ट्रांज़िट आइकन — ट्रांज़िट अलार्म। आकार रूट प्रकार दर्शाता है: ट्रेन, मेट्रो, बस, फेरी आदि।\n• नीले रिपीट तीर — प्रत्येक यात्रा के बाद अलार्म स्वतः रीसेट होता है।\n• हरा मेगाफ़ोन — स्वतः सूचना चालू है; बजने पर संपर्कों को संदेश भेजा जाएगा।\n• धूसर घंटी स्लैश — ध्वनि केवल कंपन पर सेट है, कोई ऑडियो नहीं।\n• बैंगनी समय सीमा — अलार्म केवल निर्दिष्ट समय-सीमा में सक्रिय।\n• नारंगी दिन के अक्षर — अलार्म केवल चुने हुए सप्ताह के दिनों में सक्रिय।\n\nदाईं ओर के आइकन:\n• लाल बैज घंटी — अलार्म बज चुका है और पुष्टि या स्नूज़ की प्रतीक्षा में है।\n• नारंगी चंद्रमा Z के साथ — अलार्म अभी स्नूज़ में है।";
"help.body.managingAlarms" = "किसी भी अलार्म पर दाईं ओर स्वाइप करें, विवरण खोले बिना जल्दी से चालू या बंद करें।\n\nहटाने के लिए बाईं ओर स्वाइप करें। हटाए गए अलार्म तुरंत हट जाते हैं और उनका जियोफेंस मॉनिटरिंग बंद हो जाती है।\n\nअलार्म संपादित करने के लिए, विवरण खोलने के लिए टैप करें, फिर अलार्म संपादित करें दबाएँ।\n\nअलार्म स्थान साझा करने के लिए, विवरण खोलें और अलार्म स्थान साझा करें दबाएँ। यह अलार्म के निश्चित पिन किए गए निर्देशांक का एक Apple Maps लिंक भेजता है — यात्रा से पहले किसी को अपना गंतव्य बताने के लिए उपयोगी। इसे किसी भी समय साझा किया जा सकता है, न केवल जब अलार्म बजे।";

"help.body.alwaysOnLocation" = "GeoNap को बैकग्राउंड में क्षेत्रों की निगरानी के लिए हमेशा चालू लोकेशन एक्सेस की ज़रूरत है — तब भी जब आपकी स्क्रीन लॉक हो या ऐप बंद हो।\n\nअगर सेटअप के दौरान अभी नहीं चुना था, तो बाद में iOS सेटिंग्स → गोपनीयता और सुरक्षा → लोकेशन सेवाएँ → GeoNap में जाकर अनुमति दे सकते हैं। इसे हमेशा पर सेट करें।\n\nहमेशा चालू एक्सेस के बिना, अलार्म केवल तभी बजेंगे जब ऐप खुला हो।";

"help.body.notifications" = "जब अलार्म बजे तो अलार्म नाम और आपका नोट (यदि सेट है) के साथ सूचना मिलेगी। सूचना से आप:\n\n• 10 मिनट स्नूज़ — 10 मिनट के लिए अलार्म दबाता है, फिर दोबारा चालू करता है।\n• खारिज करें — सूचना साफ़ करता है। बार-बार दोहराने वाले अलार्म के लिए, जब आप क्षेत्र छोड़ें तो अलार्म रीसेट होता है।\n\nयदि अलार्म पर स्वतः सूचना सक्षम है, तो अगली बार जब आप GeoNap को अग्रभूमि में लाएंगे, Messages ऐप स्वचालित रूप से खुलेगा। संदेश पहले से भरा हुआ होगा — उदाहरण के लिए: \"[आगमन] मैं [स्टेशन का नाम] पर [समय] बजे पहुँचा।\" पुष्टि करने के लिए भेजें टैप करें।\n\nसुनिश्चित करें कि iOS सेटिंग्स → सूचनाएँ → GeoNap में सूचनाएँ चालू हैं।";

