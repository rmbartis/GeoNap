// MARK: - PrivacyView Body Text
"privacy.intro" = "GeoNap एक सरल सिद्धांत के साथ बनाया गया है: आपकी लोकेशन और अलार्म डेटा आपका है। यह दस्तावेज़ बताता है कि ऐप कौन सी जानकारी उपयोग करता है, कहाँ रहती है और वह क्या कभी नहीं करता।";

"privacy.body.locationData" = "GeoNap आपके डिवाइस की लोकेशन का उपयोग केवल जियोफेंस्ड क्षेत्रों की निगरानी के लिए करता है। लोकेशन डेटा पूरी तरह आपके डिवाइस पर संसाधित होता है — इसे कभी किसी सर्वर पर नहीं भेजा जाता, डेटाबेस में संग्रहीत नहीं किया जाता या तृतीय पक्षों के साथ साझा नहीं किया जाता।\n\nजब आप अलार्म बनाते हैं, अक्षांश, देशांतर और रेडियस स्थानीय रूप से सहेजे जाते हैं। यह डेटा आपके डिवाइस से नहीं निकलता जब तक आप स्पष्ट रूप से शेयर बटन उपयोग न करें, जो एक मानक Apple Maps लिंक बनाता है।\n\nऐप \"हमेशा चालू\" लोकेशन अनुमति माँगता है ताकि iOS बैकग्राउंड में ऐप को जगा सके जब आप किसी निगरानी क्षेत्र में प्रवेश करें या बाहर निकलें। आप iOS सेटिंग्स → गोपनीयता और सुरक्षा → लोकेशन सेवाएँ → GeoNap में किसी भी समय यह अनुमति रद्द कर सकते हैं।";

"privacy.body.onDeviceStorage" = "सभी अलार्म डेटा — नाम, निर्देशांक, रेडियस, टाइम विंडो, सक्रिय दिन और ट्रिगर इतिहास सहित — ऐप के निजी कंटेनर में SwiftData का उपयोग करके स्थानीय रूप से संग्रहीत होता है। यह डेटा मानक iOS बैकअप (iCloud Backup या iTunes/Finder) में शामिल है अगर बैकअप सक्षम हैं।\n\nGeoNap उपयोग करने के लिए कोई खाता, लॉगिन या नेटवर्क कनेक्शन की ज़रूरत नहीं।";

"privacy.body.iCloudSync" = "GeoNap को CloudKit के माध्यम से iCloud सिंक सपोर्ट करने के लिए डिज़ाइन किया गया है ताकि आपके अलार्म उन सभी Apple डिवाइसों पर दिख सकें जो एक ही Apple ID से साइन इन हों। जब iCloud सिंक सक्रिय हो, अलार्म रिकॉर्ड आपके निजी iCloud कंटेनर में संग्रहीत होते हैं और Apple की गोपनीयता नीति द्वारा नियंत्रित होते हैं। Apple विज्ञापन के लिए CloudKit डेटा उपयोग नहीं करता।\n\nअगर iCloud सिंक अनुपलब्ध या अक्षम है, ऐप स्वतः केवल-स्थानीय स्टोरेज पर वापस आ जाता है — कोई डेटा नहीं खोता। आप सेटिंग्स → [आपका नाम] → iCloud → GeoNap में किसी भी समय iCloud सिंक अक्षम कर सकते हैं।";

"privacy.body.transitFeeds" = "ट्रांज़िट अलार्म सुविधा सार्वजनिक परिवहन एजेंसी सर्वरों से सीधे GTFS डेटा डाउनलोड करती है। इन फ़ीड में स्टॉप नाम, निर्देशांक और रूट जानकारी होती है — कोई व्यक्तिगत डेटा शामिल नहीं।\n\nडाउनलोड किया गया GTFS डेटा आपके डिवाइस पर ऐप के कैश डायरेक्टरी में कैश होता है। जब स्टोरेज कम हो तो iOS कैश फ़ाइलें हटा सकता है; ऐप माँग पर फिर से डाउनलोड करेगा।\n\nआपका दर्ज कोई भी कस्टम GTFS URL वर्तमान सत्र से आगे संग्रहीत नहीं होता, और आपने कौन सी एजेंसियाँ ब्राउज़ कीं इसकी कोई जानकारी कहीं प्रसारित नहीं होती।";

"privacy.body.notifications" = "GeoNap iOS के UNUserNotificationCenter का उपयोग करके पूरी तरह ऑन-डिवाइस स्थानीय सूचनाएँ भेजता है। जब कोई जियोफेंस इवेंट बजे तो ऐप स्वयं सूचनाएँ उत्पन्न करता है — इन्हें किसी पुश नोटिफिकेशन सर्वर या रिमोट सेवा के माध्यम से नहीं भेजा जाता। आपके डिवाइस से कोई सूचना सामग्री नहीं भेजी जाती।\n\nआप iOS सेटिंग्स → सूचनाएँ → GeoNap में नोटिफिकेशन अनुमतियाँ प्रबंधित कर सकते हैं।";

"privacy.body.analytics" = "GeoNap में कोई तृतीय-पक्ष एनालिटिक्स SDK, विज्ञापन नेटवर्क या क्रैश रिपोर्टिंग सेवाएँ शामिल नहीं हैं। ऐप आपके उपयोग को ट्रैक नहीं करता और iOS द्वारा सेटिंग्स → गोपनीयता और सुरक्षा → विश्लेषण और सुधार में स्वाभाविक रूप से प्रदान की गई जानकारी से परे नैदानिक जानकारी एकत्र नहीं करता।";

"privacy.body.dataDeletion" = "आप किसी भी अलार्म पंक्ति पर बाईं ओर स्वाइप करके अलग-अलग अलार्म हटा सकते हैं, या डिवाइस से ऐप हटाकर सभी डेटा मिटा सकते हैं। GeoNap हटाने से स्थानीय रूप से संग्रहीत सभी अलार्म रिकॉर्ड हट जाते हैं। अगर iCloud सिंक सक्षम था, तो आप सेटिंग्स → [आपका नाम] → iCloud → खाता स्टोरेज प्रबंधित करें → GeoNap में भी ऐप का CloudKit डेटा हटा सकते हैं।";

"privacy.body.contact" = "अगर आपके गोपनीयता या डेटा हैंडलिंग के बारे में प्रश्न हैं, तो आप GeoNap के प्रोडक्ट पेज पर App Store सपोर्ट लिंक के माध्यम से डेवलपर से संपर्क कर सकते हैं।";

