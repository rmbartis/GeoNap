// MARK: - PrivacyView Body Text
"privacy.intro" = "صُمّم GeoNap وفق مبدأ بسيط: بيانات موقعك ومنبّهاتك ملكٌ لك. يشرح هذا المستند بدقّة المعلومات التي يستخدمها التطبيق، وأين تبقى، وما لن يفعله أبدًا.";

"privacy.body.locationData" = "يستخدم GeoNap موقع جهازك حصريًا لرصد المناطق الجغرافية المسيّجة. تُعالَج بيانات الموقع بالكامل على جهازك — ولا تُنقل إلى أيّ خادم، ولا تُخزَّن في قاعدة بيانات، ولا تُشارَك مع أطراف ثالثة.\n\nعند إنشاء منبّه، يُحفظ خطّ العرض وخطّ الطول ونصف القطر محليًا. لا تغادر هذه البيانات جهازك إلا إن استخدمت زرّ المشاركة صراحةً، الذي يُنشئ رابط Apple Maps قياسيًا.\n\nيطلب التطبيق صلاحية الموقع \"الدائم\" لكي يتمكّن iOS من تشغيل التطبيق في الخلفية حين تدخل منطقة مراقَبة أو تخرج منها. يمكنك إلغاء هذه الصلاحية في أيّ وقت من إعدادات iOS ← الخصوصية والأمان ← خدمات الموقع ← GeoNap.";

"privacy.body.onDeviceStorage" = "تُخزَّن جميع بيانات المنبّهات — بما فيها الأسماء والإحداثيات والأنصاف والنوافذ الزمنية والأيام النشطة وسجلّ التشغيل — محليًا باستخدام SwiftData في الحاوية الخاصة بالتطبيق. تُدرَج هذه البيانات في نسخ iOS الاحتياطية القياسية (iCloud Backup أو iTunes/Finder) إن كانت النسخ الاحتياطية مفعّلة.\n\nلا حاجة إلى حساب أو تسجيل دخول أو اتصال بالشبكة لاستخدام GeoNap.";

"privacy.body.iCloudSync" = "صُمّم GeoNap ليدعم مزامنة iCloud عبر CloudKit لتظهر منبّهاتك على جميع أجهزة Apple المسجّل دخولها بنفس Apple ID. حين تكون مزامنة iCloud نشطة، تُخزَّن سجلّات المنبّهات في حاويتك الشخصية على iCloud وتخضع لسياسة خصوصية Apple. لا تستخدم Apple بيانات CloudKit للإعلانات.\n\nإن كانت مزامنة iCloud غير متاحة أو معطّلة، يعود التطبيق تلقائيًا إلى التخزين المحلي فحسب — دون فقدان أيّ بيانات. يمكنك تعطيل مزامنة iCloud في أيّ وقت من الإعدادات ← [اسمك] ← iCloud ← GeoNap.";

"privacy.body.transitFeeds" = "تُنزّل ميزة منبّه المواصلات بيانات GTFS مباشرةً من خوادم جهات النقل العام. تحتوي هذه البيانات على أسماء المحطات وإحداثياتها ومعلومات المسارات — ولا تشمل أيّ بيانات شخصية.\n\nتُخزَّن بيانات GTFS المنزَّلة في مجلّد ذاكرة التخزين المؤقت للتطبيق على جهازك. قد يحذف iOS الملفات المخزَّنة حين تشحّ المساحة؛ سيُعيد التطبيق تنزيلها عند الطلب.\n\nلا يُحفظ أيّ رابط GTFS مخصّص تُدخله لما بعد الجلسة الحالية، ولا تُرسَل أيّ معلومات حول الجهات التي تصفّحتها.";

"privacy.body.notifications" = "يُرسل GeoNap إشعارات محلية بالكامل على الجهاز باستخدام UNUserNotificationCenter الخاص بـ iOS. تُنشئ الإشعارات التطبيقُ نفسُه حين يقع حدث السياج الجغرافي — ولا تُرسَل عبر أيّ خادم إشعارات دفعية أو خدمة بعيدة. لا يخرج أيّ محتوى إشعار من جهازك.\n\nيمكنك إدارة أذونات الإشعارات من إعدادات iOS ← الإشعارات ← GeoNap.";

"privacy.body.analytics" = "لا يتضمّن GeoNap أيّ حزم SDK تحليلية تابعة لجهات خارجية، ولا شبكات إعلانية، ولا خدمات تقارير الأعطال. لا يتتبّع التطبيق كيفية استخدامك له، ولا يجمع معلومات تشخيصية سوى ما يوفّره iOS أصلًا في الإعدادات ← الخصوصية والأمان ← التحليلات والتحسينات.";

"privacy.body.dataDeletion" = "يمكنك حذف منبّهات فردية بالتمرير يسارًا على صفّ أيّ منبّه، أو حذف جميع البيانات بإزالة التطبيق من جهازك. تؤدّي إزالة GeoNap إلى حذف جميع سجلّات المنبّهات المخزَّنة محليًا. إن كانت مزامنة iCloud مفعّلة، يمكنك أيضًا حذف بيانات CloudKit للتطبيق من الإعدادات ← [اسمك] ← iCloud ← إدارة مساحة تخزين الحساب ← GeoNap.";

"privacy.body.contact" = "إن كان لديك أسئلة حول الخصوصية أو التعامل مع البيانات، يمكنك التواصل مع المطوّر عبر رابط الدعم في App Store على صفحة منتج GeoNap.";

