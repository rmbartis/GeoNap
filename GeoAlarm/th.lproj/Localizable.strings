// MARK: - PrivacyView Body Text
"privacy.intro" = "GeoNap ออกแบบโดยยึดหลักการง่าย ๆ: ข้อมูลตำแหน่งและนาฬิกาปลุกของคุณเป็นของคุณ เอกสารนี้อธิบายอย่างชัดเจนว่าแอปใช้ข้อมูลอะไร เก็บไว้ที่ไหน และสิ่งที่แอปไม่เคยทำ";

"privacy.body.locationData" = "GeoNap ใช้ตำแหน่งของอุปกรณ์คุณเพื่อตรวจจับพื้นที่เฝ้าระวังเท่านั้น ข้อมูลตำแหน่งถูกประมวลผลบนอุปกรณ์ของคุณทั้งหมด — ไม่มีการส่งไปยังเซิร์ฟเวอร์ใด ๆ ไม่มีการเก็บในฐานข้อมูล และไม่มีการแชร์กับบุคคลที่สาม\n\nเมื่อคุณสร้างนาฬิกาปลุก ละติจูด ลองจิจูด และรัศมีจะถูกบันทึกในเครื่อง ข้อมูลนี้จะไม่ออกจากอุปกรณ์ของคุณ เว้นแต่คุณจะใช้ปุ่มแชร์อย่างชัดเจน ซึ่งจะสร้างลิงก์ Apple Maps มาตรฐาน\n\nแอปขอสิทธิ์ตำแหน่ง \"เปิดตลอดเวลา\" เพื่อให้ iOS สามารถปลุกแอปในเบื้องหลังเมื่อคุณเข้าหรือออกจากพื้นที่เฝ้าระวัง คุณสามารถเพิกถอนสิทธิ์นี้ได้ตลอดเวลาใน การตั้งค่า → ความเป็นส่วนตัวและความปลอดภัย → บริการระบุตำแหน่ง → GeoNap";

"privacy.body.onDeviceStorage" = "ข้อมูลนาฬิกาปลุกทั้งหมด — รวมถึงชื่อ พิกัด รัศมี ช่วงเวลา วันที่ใช้งาน และประวัติการทริกเกอร์ — จะถูกเก็บในเครื่องโดยใช้ SwiftData ในคอนเทนเนอร์ส่วนตัวของแอป ข้อมูลนี้รวมอยู่ในการสำรองข้อมูล iOS มาตรฐาน (iCloud Backup หรือ iTunes/Finder) หากเปิดใช้งานการสำรองข้อมูล\n\nไม่จำเป็นต้องมีบัญชี การเข้าสู่ระบบ หรือการเชื่อมต่อเครือข่ายเพื่อใช้ GeoNap";

"privacy.body.iCloudSync" = "GeoNap ออกแบบมาเพื่อรองรับการซิงค์ iCloud ผ่าน CloudKit เพื่อให้นาฬิกาปลุกของคุณปรากฏบนอุปกรณ์ Apple ทั้งหมดที่ลงชื่อเข้าใช้ Apple ID เดียวกัน เมื่อการซิงค์ iCloud ทำงาน บันทึกนาฬิกาปลุกจะถูกเก็บในคอนเทนเนอร์ iCloud ส่วนตัวของคุณและอยู่ภายใต้นโยบายความเป็นส่วนตัวของ Apple Apple ไม่ใช้ข้อมูล CloudKit เพื่อการโฆษณา\n\nหากการซิงค์ iCloud ไม่พร้อมใช้งานหรือปิดการใช้งาน แอปจะสลับไปใช้พื้นที่จัดเก็บในเครื่องเท่านั้นโดยอัตโนมัติ — ไม่มีข้อมูลสูญหาย คุณสามารถปิดการซิงค์ iCloud ได้ตลอดเวลาใน การตั้งค่า → [ชื่อของคุณ] → iCloud → GeoNap";

"privacy.body.transitFeeds" = "ฟีเจอร์นาฬิกาปลุกขนส่งดาวน์โหลดข้อมูล GTFS โดยตรงจากเซิร์ฟเวอร์ของหน่วยงานขนส่งสาธารณะ ฟีดเหล่านี้ประกอบด้วยชื่อป้ายหยุด พิกัด และข้อมูลเส้นทาง — ไม่มีข้อมูลส่วนตัวรวมอยู่\n\nข้อมูล GTFS ที่ดาวน์โหลดมาจะถูกบันทึกในไดเรกทอรีแคชของแอปบนอุปกรณ์ของคุณ ไฟล์ที่แคชไว้อาจถูก iOS ลบเมื่อพื้นที่เก็บข้อมูลต่ำ แอปจะดาวน์โหลดใหม่เมื่อต้องการ\n\nไม่มีการบันทึก URL ฟีด GTFS ที่คุณป้อนเกินกว่าเซสชันปัจจุบัน และไม่มีการส่งข้อมูลเกี่ยวกับหน่วยงานที่คุณเรียกดูไปที่ใด";

"privacy.body.notifications" = "GeoNap ส่งการแจ้งเตือนในเครื่องทั้งหมดบนอุปกรณ์โดยใช้ UNUserNotificationCenter ของ iOS การแจ้งเตือนถูกสร้างโดยแอปเองเมื่อเกิดเหตุการณ์เฝ้าระวังพื้นที่ — ไม่ได้ส่งผ่านเซิร์ฟเวอร์การแจ้งเตือนแบบพุชหรือบริการระยะไกลใด ๆ ไม่มีเนื้อหาการแจ้งเตือนที่ส่งออกจากอุปกรณ์ของคุณ\n\nคุณสามารถจัดการสิทธิ์การแจ้งเตือนได้ใน การตั้งค่า → การแจ้งเตือน → GeoNap";

"privacy.body.analytics" = "GeoNap ไม่มี SDK การวิเคราะห์ของบุคคลที่สาม เครือข่ายโฆษณา หรือบริการรายงานข้อผิดพลาดใด ๆ แอปไม่ติดตามวิธีที่คุณใช้งานและไม่รวบรวมข้อมูลการวินิจฉัยนอกเหนือจากสิ่งที่ iOS จัดเตรียมให้ในการตั้งค่า → ความเป็นส่วนตัวและความปลอดภัย → การวิเคราะห์และการปรับปรุง";

"privacy.body.dataDeletion" = "คุณสามารถลบนาฬิกาปลุกแต่ละรายการได้โดยปัดซ้ายบนแถวนาฬิกาปลุก หรือลบข้อมูลทั้งหมดโดยนำแอปออกจากอุปกรณ์ การถอนการติดตั้ง GeoNap จะลบบันทึกนาฬิกาปลุกที่เก็บในเครื่องทั้งหมด หากเปิดใช้งานการซิงค์ iCloud คุณยังสามารถลบข้อมูล CloudKit ของแอปได้ใน การตั้งค่า → [ชื่อของคุณ] → iCloud → จัดการพื้นที่เก็บข้อมูลบัญชี → GeoNap";

"privacy.body.contact" = "หากคุณมีคำถามเกี่ยวกับความเป็นส่วนตัวหรือการจัดการข้อมูล คุณสามารถติดต่อนักพัฒนาผ่านลิงก์สนับสนุนใน App Store บนหน้าผลิตภัณฑ์ GeoNap";

