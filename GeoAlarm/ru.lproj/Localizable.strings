// MARK: - PrivacyView Body Text
"privacy.intro" = "GeoNap разработан на основе простого принципа: ваши данные о местоположении и будильники принадлежат вам. Этот документ точно объясняет, какую информацию использует приложение, где она хранится и чего оно никогда не делает.";

"privacy.body.locationData" = "GeoNap использует местоположение вашего устройства исключительно для мониторинга геозон. Данные о местоположении обрабатываются полностью на вашем устройстве — они никогда не передаются на какой-либо сервер, не хранятся в базе данных и не передаются третьим лицам.\n\nКогда вы создаёте будильник, широта, долгота и радиус сохраняются локально. Эти данные не покидают ваше устройство, если только вы явно не используете кнопку «Поделиться», которая создаёт стандартную ссылку Apple Maps.\n\nПриложение запрашивает разрешение на местоположение «Всегда», чтобы iOS могла запускать приложение в фоне, когда вы входите в отслеживаемый регион или покидаете его. Вы можете отозвать это разрешение в любое время в Настройках iOS → Конфиденциальность и безопасность → Геолокация → GeoNap.";

"privacy.body.onDeviceStorage" = "Все данные будильников — включая названия, координаты, радиусы, временны́е окна, активные дни и историю срабатываний — хранятся локально с использованием SwiftData в приватном контейнере приложения. Эти данные включены в стандартные резервные копии iOS (iCloud Backup или iTunes/Finder), если резервное копирование включено.\n\nДля использования GeoNap не требуется учётная запись, вход в систему или подключение к сети.";

"privacy.body.iCloudSync" = "GeoNap поддерживает синхронизацию через iCloud с помощью CloudKit, чтобы ваши будильники появлялись на всех устройствах Apple, вошедших в один Apple ID. Когда синхронизация iCloud активна, записи будильников хранятся в вашем личном контейнере iCloud и регулируются политикой конфиденциальности Apple. Apple не использует данные CloudKit для рекламы.\n\nЕсли синхронизация iCloud недоступна или отключена, приложение автоматически переключается на только локальное хранение — данные не теряются. Вы можете отключить синхронизацию iCloud в любое время в Настройках → [Ваше имя] → iCloud → GeoNap.";

"privacy.body.transitFeeds" = "Функция транспортных будильников загружает данные GTFS напрямую с серверов агентств общественного транспорта. Эти фиды содержат названия остановок, координаты и информацию о маршрутах — личные данные не включены.\n\nЗагруженные данные GTFS кэшируются в директории кэша приложения на вашем устройстве. Кэшированные файлы могут быть удалены iOS при нехватке места; приложение загрузит их повторно по запросу.\n\nНикакой пользовательский URL GTFS не сохраняется за пределами текущего сеанса, и никакая информация о просмотренных вами агентствах никуда не передаётся.";

"privacy.body.notifications" = "GeoNap отправляет локальные уведомления полностью на устройстве, используя UNUserNotificationCenter iOS. Уведомления генерируются самим приложением при возникновении события геозоны — они не отправляются через серверы push-уведомлений или удалённые сервисы. Содержимое уведомлений не передаётся за пределы вашего устройства.\n\nВы можете управлять разрешениями на уведомления в Настройках iOS → Уведомления → GeoNap.";

"privacy.body.analytics" = "GeoNap не содержит сторонних аналитических SDK, рекламных сетей или сервисов отчётов об ошибках. Приложение не отслеживает, как вы его используете, и не собирает диагностическую информацию помимо той, что iOS предоставляет нативно в Настройках → Конфиденциальность и безопасность → Аналитика и улучшения.";

"privacy.body.dataDeletion" = "Вы можете удалить отдельные будильники, проведя пальцем влево по строке будильника, или удалить все данные, удалив приложение с устройства. Удаление GeoNap удаляет все локально сохранённые записи будильников. Если была включена синхронизация iCloud, вы также можете удалить данные CloudKit приложения в Настройках → [Ваше имя] → iCloud → Управление хранилищем учётной записи → GeoNap.";

"privacy.body.contact" = "Если у вас есть вопросы о конфиденциальности или обработке данных, вы можете связаться с разработчиком через ссылку поддержки в App Store на странице продукта GeoNap.";

